// Файл: zmk-config/config/pncateho.overlay
#include <dt-bindings/zmk/matrix-transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-direct";
        // Перечисляем все 10 пинов в порядке, указанном в info.json:
        // первые 5: F7, F6, F5, F4, B6
        // вторые 5: B2, B3, B1, E6, B4
        input-gpios
            = <&pro_micro 18 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 0: верх1 (F7)
            , <&pro_micro 19 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 1: верх2 (F6)
            , <&pro_micro 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 2: верх3 (F5)
            , <&pro_micro 21 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 3: верх4 (F4)
            , <&pro_micro 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 4: левый thumb (B6)
            , <&pro_micro 16 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 5: ниж1 (B2)
            , <&pro_micro 14 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 6: ниж2 (B3)
            , <&pro_micro 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 7: ниж3 (B1)
            , <&pro_micro 8  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // 8: ниж4 (E6)
            , <&pro_micro 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; // 9: правый thumb (B4)
    };

    // Определяем логическую матрицу 3x4:
    // - ряд 0: верхний (4 клавиши)
    // - ряд 1: нижний (4 клавиши)
    // - ряд 2: thumb (2 клавиши)
    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <4>;
        rows = <3>;
        // Сопоставляем физические индексы (0-9) с позициями (row, col)
        map = <
            // Верхний ряд (row 0, col 0..3)
            RC(0,0) RC(0,1) RC(0,2) RC(0,3)    // индексы 0,1,2,3
            // Нижний ряд (row 1, col 0..3)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3)    // индексы 5,6,7,8
            // Thumb-клавиши (row 2, col 0 и col 1)
            RC(2,0) RC(2,1)                     // индексы 4 и 9
            // Остальные 4 ячейки матрицы (row 2, col 2,3 и row 0-1, col 4? у нас только 4 колонки) остаются пустыми
        >;
    };
};